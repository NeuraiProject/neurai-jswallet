{
  "name": "@neuraiproject/neurai-jswallet",
  "version": "0.13.3",
  "description": "Neurai JavaScript wallet library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/browser.js",
  "types": "./dist/entries/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/entries/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/entries/index.d.ts",
      "import": "./dist/browser.js"
    },
    "./global": "./dist/NeuraiJsWallet.global.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && rollup -c rollup.config.mjs",
    "build:ts": "tsc -p tsconfig.json",
    "test": "npm run build && mocha ./src/tests",
    "test:run": "mocha ./src/tests",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neuraiproject/neurai-jswallet.git"
  },
  "keywords": [
    "Neurai"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/neuraiproject/neurai-jswallet/issues"
  },
  "dependencies": {
    "@neuraiproject/neurai-assets": "1.3.1",
    "@neuraiproject/neurai-create-transaction": "0.3.1",
    "@neuraiproject/neurai-key": "4.0.0",
    "@neuraiproject/neurai-rpc": "0.4.7",
    "@neuraiproject/neurai-scripts": "0.5.1",
    "@neuraiproject/neurai-sign-transaction": "2.1.2"
  },
  "homepage": "https://github.com/neuraiproject/neurai-jswallet#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.8",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^20.8.0",
    "chai": "^4.3.10",
    "mocha": "^11.7.5",
    "rollup": "^4.52.4",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^9.0.0"
  }
}
